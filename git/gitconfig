[push]
default = simple
autoSetupRemote = true
[credential]
helper = osxkeychain
[init]
defaultBranch = main
[user]
name = Eli Itah
email = elijahbit@gmail.com
signingkey = A874FA3798BA87C5 # eli 16 inch macbook credential
[code]
excludesfile = ~/.gitignore
[core]
excludesfile = ~/.gitignore
editor = code --wait
[alias]
hist = log --graph --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --all -20
co = checkout
[color]
diff = auto
status = auto
branch = auto
ui = true
[pager]
branch = false
[rerere]
enabled = true
# Use epsilon identity for any repo with a Bitbucket (cnvrmedia) remote.
[includeIf "hasconfig:remote.*.url:ssh://git@git.cnvrmedia.net:7999/**"]
path = ~/dotfiles/git/gitconfig-epsilon
